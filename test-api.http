### 1. เพิ่มคอมเมนท์ (ต้องมี Token)
POST http://localhost:8899/api/posts/comment
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6NSwidXNlcm5hbWUiOiJzb21lb25lX2RldiIsImlhdCI6MTc3Mzk5NTc0MCwiZXhwIjoxNzc0NjAwNTQwfQ.IkM2SMEGvaLTfZrFoE77IoB9JLXR0U1QC_a2OGPeB-g
Content-Type: application/json

{
  "postId": 2,
  "message": "กำลังเดินทางไปช่วยน้องครับ!"
}

### 2. ดึงคอมเมนท์ (ต้องมี Token แล้วเช่นกัน)
GET http://localhost:8899/api/posts/2/comments
