# Register api
POST http://localhost:8899/api/auth/register HTTP/1.1
content-type: application/json

{
  "username": "someone_dev",
  "email": "someone@ggg.mail",
  "firstName": "someone",
  "lastName": "codecamp",
  "password": "123456"
}
###

# Login api
POST http://localhost:8899/api/auth/login HTTP/1.1
Content-Type: application/json

{
  "email": "someone@ggg.mail",
  "password": "123456"
}
###



### Get Current User Profile
GET http://localhost:8899/api/auth/users/me
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6NSwidXNlcm5hbWUiOiJzb21lb25lX2RldiIsImlhdCI6MTc3Mzk5NTc0MCwiZXhwIjoxNzc0NjAwNTQwfQ.IkM2SMEGvaLTfZrFoE77IoB9JLXR0U1QC_a2OGPeB-g



### Create Rescue Post (สร้างโพสต์ขอความช่วยเหลือ - หมา)
POST http://localhost:8899/api/posts
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6NSwidXNlcm5hbWUiOiJzb21lb25lX2RldiIsImlhdCI6MTc3Mzk5NTc0MCwiZXhwIjoxNzc0NjAwNTQwfQ.IkM2SMEGvaLTfZrFoE77IoB9JLXR0U1QC_a2OGPeB-g
Content-Type: application/json

{
  "message": "พบสุนัขบาดเจ็บหน้าเซเว่น",
  "postType": "RESCUE",
  "details": {
    "animalType": "DOG",
    "location": "สุขุมวิท 101",
    "isHelperNeeded": true
  }
}

### Create Adoption Post (สร้างโพสต์หาบ้านใหม่)
POST http://localhost:8899/api/posts
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6NSwidXNlcm5hbWUiOiJzb21lb25lX2RldiIsImlhdCI6MTc3Mzk5NTc0MCwiZXhwIjoxNzc0NjAwNTQwfQ.IkM2SMEGvaLTfZrFoE77IoB9JLXR0U1QC_a2OGPeB-g
Content-Type: application/json

{
  "message": "น้องแมวส้มหาบ้านที่อบอุ่นครับ",
  "postType": "ADOPT"
}



