generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id               Int               @id @default(autoincrement())
  username         String            @unique
  password         String
  email            String            @unique
  firstName        String
  lastName         String
  bio              String?           @db.Text
  profileImage     String?           @default("default_profile.png")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  adoptions        Adoption[]        @relation("AdopterRelation")
  adoptionRequests AdoptionRequest[]
  catRescues       CatCase[]         @relation("CatHelper")
  comments         Comment[]
  dogRescues       DogCase[]         @relation("DogHelper")
  likes            Like[]
  posts            Post[]
}

model Post {
  id               Int               @id @default(autoincrement())
  message          String?           @db.Text
  image            String?
  postType         PostType
  userId           Int
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  adoption         Adoption?
  adoptionRequests AdoptionRequest[]
  catCase          CatCase?
  comments         Comment[]
  dogCase          DogCase?
  likes            Like[]
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "Post_userId_fkey")
}

model DogCase {
  id             Int        @id @default(autoincrement())
  postId         Int        @unique
  status         CaseStatus @default(PENDING)
  location       String
  urgentLevel    String     @default("LOW")
  isHelperNeeded Boolean    @default(true)
  helperId       Int?
  helper         User?      @relation("DogHelper", fields: [helperId], references: [id])
  post           Post       @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([helperId], map: "DogCase_helperId_fkey")
}

model CatCase {
  id             Int        @id @default(autoincrement())
  postId         Int        @unique
  status         CaseStatus @default(PENDING)
  location       String
  urgentLevel    String     @default("LOW")
  isHelperNeeded Boolean    @default(true)
  helperId       Int?
  helper         User?      @relation("CatHelper", fields: [helperId], references: [id])
  post           Post       @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([helperId], map: "CatCase_helperId_fkey")
}

model Adoption {
  id        Int     @id @default(autoincrement())
  postId    Int     @unique
  location  String?
  adopterId Int?
  isConfirm Boolean @default(false)
  adopter   User?   @relation("AdopterRelation", fields: [adopterId], references: [id])
  post      Post    @relation(fields: [postId], references: [id])

  @@index([adopterId], map: "Adoption_adopterId_fkey")
}

model Comment {
  id        Int      @id @default(autoincrement())
  message   String?  @db.Text
  image     String?
  userId    Int
  postId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId], map: "Comment_postId_fkey")
  @@index([userId], map: "Comment_userId_fkey")
}

model Like {
  userId    Int
  postId    Int
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId], map: "Like_postId_fkey")
}

model AdoptionRequest {
  id        Int        @id @default(autoincrement())
  postId    Int
  userId    Int
  status    CaseStatus @default(PENDING)
  createdAt DateTime   @default(now())
  post      Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId], map: "AdoptionRequest_userId_fkey")
}

enum PostType {
  RESCUE
  ADOPT
  HAPPY
}

enum CaseStatus {
  PENDING
  RESERVED
  COMPLETED
}
